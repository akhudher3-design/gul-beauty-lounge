  <!-- Process Section -->
  <section id="process" class="relative py-20 md:py-32 lg:py-40 overflow-hidden" style="background-color: var(--bg-cream);">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-12 md:mb-24">
        <p class="text-gold text-xs tracking-[0.35em] uppercase mb-4 process-reveal">Behandlungsablauf</p>
        <h2 class="font-serif text-2xl sm:text-3xl md:text-4xl lg:text-5xl process-reveal" style="color: var(--text-charcoal);">So lauft dein Besuch ab</h2>
      </div>

      <div class="relative" id="process-timeline">
        <!-- Vertical line -->
        <div class="process-line absolute left-4 md:left-1/2 top-0 bottom-0 w-px md:-translate-x-px">
          <div class="process-line-fill absolute inset-x-0 top-0 h-0 bg-gradient-to-b from-gold via-rosegold to-gold/30"></div>
        </div>

        <div class="space-y-10 md:space-y-20">
          <!-- Step 1 -->
          <div class="process-item relative pl-12 md:pl-0 md:grid md:grid-cols-2 md:gap-12 items-center" data-process="0">
            <div class="md:text-right md:pr-12">
              <span class="process-num inline-block text-gold/50 text-sm font-mono mb-2">01</span>
              <h3 class="font-serif text-xl md:text-2xl lg:text-3xl mb-2 md:mb-3" style="color: var(--text-charcoal);">Beratung</h3>
              <p class="max-w-sm md:ml-auto" style="color: var(--text-softgray);">Wir besprechen deine Wunsche, deinen Hautzustand und die passenden Behandlungsmoglichkeiten im Detail.</p>
            </div>
            <div class="hidden md:flex justify-start pl-12">
              <div class="process-dot w-4 h-4 rounded-full border-2 border-gold/30 relative z-10 transition-all duration-500" style="background: var(--bg-cream);"></div>
            </div>
            <div class="absolute left-4 md:left-1/2 top-1 md:-translate-x-1/2 w-4 h-4 rounded-full border-2 border-gold/30 md:hidden" style="background: var(--bg-cream);"></div>
          </div>

          <!-- Step 2 -->
          <div class="process-item relative pl-12 md:pl-0 md:grid md:grid-cols-2 md:gap-12 items-center" data-process="1">
            <div class="hidden md:flex justify-end pr-12">
              <div class="process-dot w-4 h-4 rounded-full border-2 border-gold/30 relative z-10 transition-all duration-500" style="background: var(--bg-cream);"></div>
            </div>
            <div class="md:pl-12">
              <span class="process-num inline-block text-gold/50 text-sm font-mono mb-2">02</span>
              <h3 class="font-serif text-xl md:text-2xl lg:text-3xl mb-2 md:mb-3" style="color: var(--text-charcoal);">Hautanalyse</h3>
              <p class="max-w-sm" style="color: var(--text-softgray);">Gemeinsam analysieren wir deinen Hauttyp und definieren die optimale Behandlungsstrategie fur deine Ziele.</p>
            </div>
            <div class="absolute left-4 md:left-1/2 top-1 md:-translate-x-1/2 w-4 h-4 rounded-full border-2 border-gold/30 md:hidden" style="background: var(--bg-cream);"></div>
          </div>

          <!-- Step 3 -->
          <div class="process-item relative pl-12 md:pl-0 md:grid md:grid-cols-2 md:gap-12 items-center" data-process="2">
            <div class="md:text-right md:pr-12">
              <span class="process-num inline-block text-gold/50 text-sm font-mono mb-2">03</span>
              <h3 class="font-serif text-xl md:text-2xl lg:text-3xl mb-2 md:mb-3" style="color: var(--text-charcoal);">Individuelle Behandlung</h3>
              <p class="max-w-sm md:ml-auto" style="color: var(--text-softgray);">In entspannter Atmosphare fuhre ich die Behandlung mit Prazision, Feingefuhl und hochwertigen Produkten durch.</p>
            </div>
            <div class="hidden md:flex justify-start pl-12">
              <div class="process-dot w-4 h-4 rounded-full border-2 border-gold/30 relative z-10 transition-all duration-500" style="background: var(--bg-cream);"></div>
            </div>
            <div class="absolute left-4 md:left-1/2 top-1 md:-translate-x-1/2 w-4 h-4 rounded-full border-2 border-gold/30 md:hidden" style="background: var(--bg-cream);"></div>
          </div>

          <!-- Step 4 -->
          <div class="process-item relative pl-12 md:pl-0 md:grid md:grid-cols-2 md:gap-12 items-center" data-process="3">
            <div class="hidden md:flex justify-end pr-12">
              <div class="process-dot w-4 h-4 rounded-full border-2 border-gold/30 relative z-10 transition-all duration-500" style="background: var(--bg-cream);"></div>
            </div>
            <div class="md:pl-12">
              <span class="process-num inline-block text-gold/50 text-sm font-mono mb-2">04</span>
              <h3 class="font-serif text-xl md:text-2xl lg:text-3xl mb-2 md:mb-3" style="color: var(--text-charcoal);">Pflege & Feinschliff</h3>
              <p class="max-w-sm" style="color: var(--text-softgray);">Nach der Behandlung verfeinern wir jedes Detail und sorgen fur den letzten, perfektionierenden Schliff.</p>
            </div>
            <div class="absolute left-4 md:left-1/2 top-1 md:-translate-x-1/2 w-4 h-4 rounded-full border-2 border-gold/30 md:hidden" style="background: var(--bg-cream);"></div>
          </div>

          <!-- Step 5 -->
          <div class="process-item relative pl-12 md:pl-0 md:grid md:grid-cols-2 md:gap-12 items-center" data-process="4">
            <div class="md:text-right md:pr-12">
              <span class="process-num inline-block text-gold/50 text-sm font-mono mb-2">05</span>
              <h3 class="font-serif text-xl md:text-2xl lg:text-3xl mb-2 md:mb-3" style="color: var(--text-charcoal);">Empfehlung fur Zuhause</h3>
              <p class="max-w-sm md:ml-auto" style="color: var(--text-softgray);">Du erhaltst konkrete Tipps und Pflegeempfehlungen fur zu Hause, damit das Ergebnis langanhaltend bleibt.</p>
            </div>
            <div class="hidden md:flex justify-start pl-12">
              <div class="process-dot w-4 h-4 rounded-full border-2 border-gold/30 relative z-10 transition-all duration-500" style="background: var(--bg-cream);"></div>
            </div>
            <div class="absolute left-4 md:left-1/2 top-1 md:-translate-x-1/2 w-4 h-4 rounded-full border-2 border-gold/30 md:hidden" style="background: var(--bg-cream);"></div>
          </div>

          <!-- Step 6 -->
          <div class="process-item relative pl-12 md:pl-0 md:grid md:grid-cols-2 md:gap-12 items-center" data-process="5">
            <div class="hidden md:flex justify-end pr-12">
              <div class="process-dot w-4 h-4 rounded-full border-2 border-gold/30 relative z-10 transition-all duration-500" style="background: var(--bg-cream);"></div>
            </div>
            <div class="md:pl-12">
              <span class="process-num inline-block text-gold/50 text-sm font-mono mb-2">06</span>
              <h3 class="font-serif text-xl md:text-2xl lg:text-3xl mb-2 md:mb-3" style="color: var(--text-charcoal);">Ergebnis</h3>
              <p class="max-w-sm" style="color: var(--text-softgray);">Du blickst in den Spiegel und fuhlst dich wohl – mit gepflegter, strahlender Haut und einem zufriedenen Lacheln.</p>
            </div>
            <div class="absolute left-4 md:left-1/2 top-1 md:-translate-x-1/2 w-4 h-4 rounded-full border-2 border-gold/30 md:hidden" style="background: var(--bg-cream);"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="relative py-20 md:py-32 lg:py-40 bg-charcoal overflow-hidden">
    <!-- Background glows -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80vw] h-[60vh] bg-gold/8 rounded-full blur-[150px]"></div>
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-gold text-xs tracking-[0.35em] uppercase mb-4 contact-reveal">Termin buchen</p>
      <h2 class="font-serif text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl text-white mb-4 md:mb-6 contact-reveal">Bereit fur dein personliches Beauty-Erlebnis?</h2>
      <p class="text-base md:text-lg max-w-2xl mx-auto mb-10 md:mb-12 contact-reveal" style="color: rgba(255,255,255,0.6);">
        Buche jetzt deinen Termin in der Gul Beauty Lounge und gonn dir eine Behandlung, die zu dir und deiner Haut passt.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center mb-12 md:mb-16 contact-reveal">
        <a href="tel:+4917662624983" class="magnetic-btn group inline-flex items-center justify-center gap-3 px-6 md:px-8 py-3.5 md:py-4 bg-gold text-white font-medium rounded-full hover:bg-white hover:text-charcoal transition-all duration-300 relative overflow-hidden">
          <svg class="w-5 h-5 relative z-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.56 12.56 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.56 12.56 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span class="relative z-10">Jetzt anrufen</span>
        </a>
        <a href="mailto:gulezgn85@icloud.com" class="magnetic-btn group inline-flex items-center justify-center gap-3 px-6 md:px-8 py-3.5 md:py-4 border border-white/20 text-white font-medium rounded-full hover:bg-white hover:text-charcoal transition-all duration-300">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          E-Mail schreiben
        </a>
        <a href="#" onclick="alert('Bitte rufe uns an oder schreibe eine E-Mail, um einen Termin zu vereinbaren.')" class="magnetic-btn group inline-flex items-center justify-center gap-3 px-6 md:px-8 py-3.5 md:py-4 border border-white/20 text-white font-medium rounded-full hover:bg-white hover:text-charcoal transition-all duration-300">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Termin anfragen
        </a>
      </div>

      <div class="grid sm:grid-cols-2 gap-4 md:gap-8 max-w-lg mx-auto contact-reveal">
        <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-5 md:p-6 border border-white/10 hover:border-gold/30 transition-all duration-300">
          <div class="w-9 h-9 md:w-10 md:h-10 rounded-full bg-gold/10 flex items-center justify-center text-gold mx-auto mb-3">
            <svg class="w-4 h-4 md:w-5 md:h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.56 12.56 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.56 12.56 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <p class="text-white/50 text-xs uppercase tracking-wider mb-1">Telefon</p>
          <a href="tel:+4917662624983" class="text-white font-serif text-base md:text-lg hover:text-gold transition-colors">+49 176 62624983</a>
        </div>
        <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-5 md:p-6 border border-white/10 hover:border-gold/30 transition-all duration-300">
          <div class="w-9 h-9 md:w-10 md:h-10 rounded-full bg-gold/10 flex items-center justify-center text-gold mx-auto mb-3">
            <svg class="w-4 h-4 md:w-5 md:h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <p class="text-white/50 text-xs uppercase tracking-wider mb-1">E-Mail</p>
          <a href="mailto:gulezgn85@icloud.com" class="text-white font-serif text-base md:text-lg hover:text-gold transition-colors break-all">gulezgn85@icloud.com</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-8 md:py-10 border-t border-white/5" style="background-color: var(--text-charcoal-light);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full border border-gold/30 flex items-center justify-center overflow-hidden">
            <img src="images/logo.png" alt="" class="w-full h-full object-contain p-0.5 logo-img">
          </div>
          <div>
            <span class="font-serif text-white text-sm">Gul Beauty Lounge</span>
            <span class="text-white/30 text-xs block">Skincare & Footcare Therapy</span>
          </div>
