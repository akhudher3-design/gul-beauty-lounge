<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
  <meta name="description" content="Gul Beauty Lounge – Skincare & Footcare Therapy. Professionelle Gesichtsbehandlungen, chemische Peelings, kosmetische Fußpflege und Hauttherapien in exklusiver Atmosphare.">
  <meta name="theme-color" content="#FAF8F5">
  <title>Gul Beauty Lounge – Skincare & Footcare Therapy</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
            serif: ['Playfair Display', 'serif'],
          },
          colors: {
            cream: '#FAF8F5',
            champagne: '#F5F0E8',
            ivory: '#FFFEFB',
            nude: '#E8DDD0',
            'nude-dark': '#D4C4B0',
            rosegold: '#D4A574',
            'rosegold-light': '#E4C4A4',
            gold: '#C9A96E',
            'gold-light': '#DCCBA3',
            'gold-dark': '#B08D55',
            charcoal: '#1A1A1A',
            'charcoal-light': '#2D2D2D',
            softgray: '#6B6B6B',
            warmwhite: '#FDFCFA',
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="css/style.css">
</head>
<body class="antialiased overflow-x-hidden transition-colors duration-500" style="background-color: var(--bg-cream); color: var(--text-charcoal);">

  <!-- Preloader -->
  <div id="preloader" class="fixed inset-0 z-[100] flex items-center justify-center transition-opacity duration-700" style="background-color: var(--bg-cream);">
    <div class="text-center">
      <img src="images/logo.png" alt="Gul Beauty Lounge" class="w-24 h-24 md:w-32 md:h-32 object-contain mx-auto mb-4 preloader-logo">
      <div class="w-24 h-px bg-gradient-to-r from-transparent via-gold to-transparent mx-auto preloader-line"></div>
    </div>
  </div>

  <!-- Navigation -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
    <div class="nav-inner mx-3 md:mx-6 mt-3 md:mt-4 rounded-2xl px-4 md:px-6 py-3 md:py-4 transition-all duration-500">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <!-- Logo G -->
        <a href="#" class="flex items-center gap-2 md:gap-3 group shrink-0" aria-label="Gul Beauty Lounge Startseite">
          <div class="logo-wrap w-9 h-9 md:w-10 md:h-10 rounded-full border border-gold/30 flex items-center justify-center overflow-hidden backdrop-blur-sm" style="background: var(--bg-card);">
            <span class="font-serif text-gold text-lg md:text-xl">G</span>
          </div>
          <div class="hidden sm:block">
            <span class="font-serif text-base md:text-lg tracking-wide block leading-none" style="color: var(--text-charcoal);">Gul Beauty Lounge</span>
            <span class="text-[9px] md:text-[10px] tracking-[0.2em] uppercase" style="color: var(--text-softgray);">Skincare & Footcare Therapy</span>
          </div>
        </a>

        <!-- Desktop Nav + Theme Toggle -->
        <div class="hidden lg:flex items-center gap-6 xl:gap-8">
          <a href="#about" class="nav-link text-sm transition-colors duration-300 relative group" style="color: var(--text-softgray);" onmouseover="this.style.color='var(--text-charcoal)'" onmouseout="this.style.color='var(--text-softgray)'">Uber uns<span class="absolute -bottom-1 left-0 w-0 h-px bg-gold transition-all duration-300 group-hover:w-full"></span></a>
          <a href="#services" class="nav-link text-sm transition-colors duration-300 relative group" style="color: var(--text-softgray);" onmouseover="this.style.color='var(--text-charcoal)'" onmouseout="this.style.color='var(--text-softgray)'">Leistungen<span class="absolute -bottom-1 left-0 w-0 h-px bg-gold transition-all duration-300 group-hover:w-full"></span></a>
          <a href="#why" class="nav-link text-sm transition-colors duration-300 relative group" style="color: var(--text-softgray);" onmouseover="this.style.color='var(--text-charcoal)'" onmouseout="this.style.color='var(--text-softgray)'">Warum wir<span class="absolute -bottom-1 left-0 w-0 h-px bg-gold transition-all duration-300 group-hover:w-full"></span></a>
          <a href="#process" class="nav-link text-sm transition-colors duration-300 relative group" style="color: var(--text-softgray);" onmouseover="this.style.color='var(--text-charcoal)'" onmouseout="this.style.color='var(--text-softgray)'">Ablauf<span class="absolute -bottom-1 left-0 w-0 h-px bg-gold transition-all duration-300 group-hover:w-full"></span></a>
          <a href="#contact" class="magnetic-btn px-5 xl:px-6 py-2.5 rounded-full border text-sm transition-all duration-300" style="border-color: var(--text-charcoal); color: var(--text-charcoal);" onmouseover="this.style.backgroundColor='var(--text-charcoal)'; this.style.color='var(--bg-cream)';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--text-charcoal)';">Termin buchen</a>
          
          <!-- Theme Toggle -->
          <button id="theme-toggle" class="theme-toggle relative" aria-label="Hell/Dunkel Modus wechseln">
            <svg class="sun-icon w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="moon-icon w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
        </div>

        <!-- Mobile: Theme Toggle + Menu Button -->
        <div class="lg:hidden flex items-center gap-2">
          <button id="theme-toggle-mobile" class="theme-toggle relative" aria-label="Hell/Dunkel Modus wechseln">
            <svg class="sun-icon w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="moon-icon w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
          <button id="mobile-menu-btn" class="p-2" style="color: var(--text-charcoal);" aria-label="Menu offnen">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
        </div>
      </div>
      
      <!-- Mobile Menu -->
      <div id="mobile-menu" class="lg:hidden hidden mt-4 pt-4" style="border-color: var(--border-gold);">
        <div class="flex flex-col gap-4 pb-2">
          <a href="#about" class="text-sm transition-colors py-2" style="color: var(--text-softgray);">Uber uns</a>
          <a href="#services" class="text-sm transition-colors py-2" style="color: var(--text-softgray);">Leistungen</a>
          <a href="#why" class="text-sm transition-colors py-2" style="color: var(--text-softgray);">Warum wir</a>
          <a href="#process" class="text-sm transition-colors py-2" style="color: var(--text-softgray);">Ablauf</a>
          <a href="#contact" class="text-sm font-medium py-2 text-gold">Termin buchen</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section id="hero" class="relative min-h-screen flex items-center overflow-hidden">
    <!-- Background Gradients -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-[60vw] h-[60vw] bg-rosegold/8 rounded-full blur-[120px] -translate-y-1/3 translate-x-1/4"></div>
      <div class="absolute bottom-0 left-0 w-[50vw] h-[50vw] bg-gold/6 rounded-full blur-[100px] translate-y-1/3 -translate-x-1/4"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[40vw] h-[40vw] bg-champagne/50 rounded-full blur-[80px]"></div>
    </div>

    <!-- Gold decorative lines -->
    <div class="absolute top-20 left-10 w-px h-32 bg-gradient-to-b from-transparent via-gold/40 to-transparent hidden lg:block hero-deco-line"></div>
    <div class="absolute bottom-20 right-10 w-px h-32 bg-gradient-to-b from-transparent via-gold/40 to-transparent hidden lg:block hero-deco-line"></div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 pt-28 md:pt-32 pb-16 md:pb-20 lg:pt-0 lg:pb-0">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center min-h-[calc(100vh-7rem)] lg:min-h-0 lg:py-32">
        <!-- Text + Logo -->
        <div class="hero-content text-center lg:text-left order-2 lg:order-1">
          <p class="hero-label text-gold text-xs tracking-[0.35em] uppercase mb-4 md:mb-6">Gul Beauty Lounge</p>
          
          <h1 class="hero-headline font-serif text-3xl sm:text-4xl md:text-5xl lg:text-[3.2rem] xl:text-[3.8rem] leading-[1.1] mb-4 md:mb-6" style="color: var(--text-charcoal);">
            <span class="block overflow-hidden"><span class="hero-line inline-block">Schonheit, Pflege und</span></span>
            <span class="block overflow-hidden"><span class="hero-line inline-block">Wohlbefinden in</span></span>
            <span class="block overflow-hidden"><span class="hero-line inline-block text-gold italic">exklusiver Atmosphare.</span></span>
          </h1>
          
          <p class="hero-sub text-base md:text-lg max-w-xl mx-auto lg:mx-0 mb-8 md:mb-10 leading-relaxed" style="color: var(--text-softgray);">
            In der Gul Beauty Lounge erwarten dich hochwertige Gesichtsbehandlungen, gezielte Hauttherapien und kosmetische Fusspflege mit viel Liebe zum Detail.
          </p>
          
          <div class="hero-buttons flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center lg:justify-start">
            <a href="#contact" class="magnetic-btn group inline-flex items-center justify-center gap-3 px-6 md:px-8 py-3.5 md:py-4 bg-charcoal text-white font-medium rounded-full hover:bg-gold transition-all duration-300 relative overflow-hidden">
              <span class="relative z-10">Termin buchen</span>
              <svg class="w-4 h-4 relative z-10 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </a>
            <a href="#services" class="magnetic-btn inline-flex items-center justify-center gap-3 px-6 md:px-8 py-3.5 md:py-4 border font-medium rounded-full hover:border-gold hover:text-gold transition-all duration-300" style="border-color: var(--text-charcoal); color: var(--text-charcoal); opacity: 0.2;">
              Leistungen ansehen
            </a>
          </div>

          <!-- Contact quick links -->
          <div class="mt-8 md:mt-10 flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-3 sm:gap-6 text-sm" style="color: var(--text-softgray);">
            <a href="tel:+4917662624983" class="flex items-center gap-2 hover:text-gold transition-colors">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.56 12.56 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.56 12.56 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              +49 176 62624983
            </a>
            <span class="hidden sm:block w-1 h-1 rounded-full bg-gold/50"></span>
            <a href="mailto:gulezgn85@icloud.com" class="flex items-center gap-2 hover:text-gold transition-colors">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              gulezgn85@icloud.com
            </a>
          </div>
        </div>

        <!-- Hero Image / Portrait -->
        <div class="hero-image-wrap relative order-1 lg:order-2 flex justify-center lg:justify-end">
          <div class="relative w-[280px] h-[380px] sm:w-[340px] sm:h-[440px] md:w-[400px] md:h-[520px] lg:w-[420px] lg:h-[560px]">
            <!-- Decorative frames -->
            <div class="absolute -inset-2 md:-inset-3 border border-gold/20 rounded-[2rem] md:rounded-[2.5rem] -z-10 hero-deco"></div>
            <div class="absolute -bottom-6 -left-6 md:-bottom-8 md:-left-8 w-28 h-28 md:w-40 md:h-40 border-l border-b border-rosegold/25 rounded-bl-[2rem] md:rounded-bl-[3rem] -z-10 hero-deco"></div>
            <div class="absolute -top-4 -right-4 md:-top-6 md:-right-6 w-20 h-20 md:w-28 md:h-28 border-t border-r border-gold/20 rounded-tr-[1.5rem] md:rounded-tr-[2rem] -z-10 hero-deco"></div>
            
            <!-- Main image container -->
            <div class="hero-image-inner relative w-full h-full rounded-[1.5rem] md:rounded-[2rem] overflow-hidden shadow-2xl shadow-charcoal/10">
              <img 
                src="images/inhaberin.jpg" 
                alt="Inhaberin der Gul Beauty Lounge" 
                class="absolute inset-0 w-full h-full object-cover hero-parallax-img"
              >
              <!-- Soft gradient overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-charcoal/15 via-transparent to-transparent pointer-events-none"></div>
              <!-- Gold corner accent -->
              <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-gold/20 to-transparent pointer-events-none"></div>
            </div>

            <!-- Floating badge -->
            <div class="hero-badge absolute -bottom-3 -right-1 sm:-bottom-4 sm:-right-2 md:bottom-8 md:-right-6 backdrop-blur-xl rounded-2xl px-4 md:px-6 py-3 md:py-4 shadow-xl shadow-charcoal/5 border border-gold/10" style="background: var(--bg-card);">
              <div class="flex items-center gap-2 md:gap-3">
                <div class="w-8 h-8 md:w-10 md:h-10 rounded-full bg-gold/10 flex items-center justify-center text-gold">
                  <svg class="w-4 h-4 md:w-5 md:h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-sm" style="color: var(--text-charcoal);">5,0 Sterne</p>
                  <p class="text-xs" style="color: var(--text-softgray);">Exzellente Bewertungen</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-6 md:bottom-10 left-1/2 -translate-x-1/2 z-10 hero-scroll">
      <div class="flex flex-col items-center gap-3" style="color: var(--text-softgray); opacity: 0.6;">
        <span class="text-[10px] tracking-[0.3em] uppercase">Entdecken</span>
        <div class="w-px h-10 bg-gradient-to-b from-gold/50 to-transparent"></div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="relative py-20 md:py-32 lg:py-40 overflow-hidden" style="background-color: var(--bg-warmwhite);">
    <div class="absolute top-0 left-0 w-[40vw] h-[40vw] bg-rosegold/5 rounded-full blur-[120px] -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
    <div class="absolute bottom-0 right-0 w-[30vw] h-[30vw] bg-gold/5 rounded-full blur-[100px] translate-x-1/3 translate-y-1/3 pointer-events-none"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-24 items-center">
        <div class="about-image-col">
          <div class="relative max-w-xs sm:max-w-sm md:max-w-md mx-auto lg:mx-0">
            <div class="about-image-wrap relative rounded-[1.5rem] md:rounded-[2rem] overflow-hidden aspect-[4/5] shadow-2xl shadow-charcoal/10">
              <img 
                src="images/inhaberin.jpg" 
                alt="Inhaberin der Gul Beauty Lounge" 
                class="absolute inset-0 w-full h-full object-cover about-parallax"
              >
              <!-- Soft overlay -->
              <div class="absolute inset-0 bg-gradient-to-tr from-charcoal/10 via-transparent to-transparent pointer-events-none"></div>
            </div>
            <!-- Decorative borders -->
            <div class="absolute -bottom-4 -right-4 md:-bottom-5 md:-right-5 w-full h-full border border-gold/20 rounded-[1.5rem] md:rounded-[2rem] -z-10"></div>
            <div class="absolute -top-4 -left-4 md:-top-5 md:-left-5 w-16 h-16 md:w-24 md:h-24 border-l border-t border-rosegold/25 rounded-tl-[1rem] md:rounded-tl-[1.5rem] -z-10"></div>
            <!-- Gold accent dot -->
            <div class="absolute -bottom-2 -left-2 w-3 h-3 md:w-4 md:h-4 rounded-full bg-gold/40 -z-10"></div>
          </div>
        </div>

        <div class="about-text-col text-center lg:text-left">
          <p class="text-gold text-xs tracking-[0.35em] uppercase mb-4 about-reveal">Uber Gul Beauty Lounge</p>
          <h2 class="font-serif text-2xl sm:text-3xl md:text-4xl lg:text-5xl leading-tight mb-6 md:mb-8 about-reveal" style="color: var(--text-charcoal);">
            Vertrauen, das man spurt
          </h2>
          <div class="space-y-4 md:space-y-6 leading-relaxed text-base md:text-lg about-reveal" style="color: var(--text-softgray);">
            <p>
              Gul Beauty Lounge steht fur professionelle Hautpflege, individuelle Beratung und Behandlungen mit viel Prazision und Feingefuhl. Jede Behandlung wird auf die Bedurfnisse deiner Haut abgestimmt – fur ein gepflegtes, frisches und naturlich schones Erscheinungsbild.
            </p>
            <p>
              Im Mittelpunkt stehen Qualitat, Hygiene, Ruhe und ein Ergebnis, mit dem du dich wohlfuhlst.
            </p>
          </div>
          <div class="mt-8 md:mt-10 flex items-center justify-center lg:justify-start gap-6 md:gap-8 about-reveal">
            <div class="text-center">
              <p class="font-serif text-2xl md:text-3xl text-gold">7+</p>
              <p class="text-xs tracking-wide uppercase mt-1" style="color: var(--text-softgray);">Jahre Erfahrung</p>
            </div>
            <div class="w-px h-12" style="background-color: var(--text-charcoal); opacity: 0.1;"></div>
            <div class="text-center">
              <p class="font-serif text-2xl md:text-3xl text-gold">1000+</p>
              <p class="text-xs tracking-wide uppercase mt-1" style="color: var(--text-softgray);">Zufriedene Kundinnen</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="relative py-20 md:py-32 lg:py-40 overflow-hidden" style="background-color: var(--bg-cream);">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80vw] h-[80vw] bg-gold/3 rounded-full blur-[150px] pointer-events-none"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-12 md:mb-20">
        <p class="text-gold text-xs tracking-[0.35em] uppercase mb-4 services-reveal">Leistungen</p>
        <h2 class="font-serif text-2xl sm:text-3xl md:text-4xl lg:text-5xl mb-4 md:mb-6 services-reveal" style="color: var(--text-charcoal);">Exklusive Behandlungen</h2>
        <p class="services-reveal" style="color: var(--text-softgray);">Hochwertige Therapien und Pflegebehandlungen, die auf deine individuellen Bedurfnisse abgestimmt sind.</p>
      </div>

      <!-- Main Service Categories -->
      <div class="space-y-12 md:space-y-24">
        
        <!-- Stria & Haartherapie -->
        <div class="grid md:grid-cols-2 gap-4 md:gap-8">
          <div class="service-card tilt-card group relative rounded-2xl p-6 md:p-10 cursor-pointer" data-tilt>
            <div class="tilt-glow rounded-2xl"></div>
            <div class="tilt-inner relative z-10">
              <div class="flex items-center gap-3 md:gap-4 mb-4 md:mb-5">
                <div class="w-10 h-10 md:w-12 md:h-12 rounded-xl bg-gold/10 flex items-center justify-center text-gold group-hover:scale-110 transition-transform duration-300 shrink-0">
                  <svg class="w-5 h-5 md:w-6 md:h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </div>
                <h3 class="font-serif text-xl md:text-2xl" style="color: var(--text-charcoal);">Stria-Therapie</h3>
              </div>
              <p class="leading-relaxed text-sm md:text-base" style="color: var(--text-softgray);">Behandlung von Narben und Dehnungsstreifen zur Verbesserung des Hautbildes. Mit gezielten Therapieansatzen fur ein ebenmaßigeres, geglattetes Erscheinungsbild.</p>
            </div>
          </div>

