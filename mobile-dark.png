        <div class="flex flex-wrap justify-center gap-4 md:gap-6 text-sm text-white/40">
          <a href="#about" class="hover:text-gold transition-colors">Uber uns</a>
          <a href="#services" class="hover:text-gold transition-colors">Leistungen</a>
