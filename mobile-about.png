        </div>

        <div class="why-card group relative rounded-2xl p-6 md:p-8 border border-gold/10 hover:border-gold/30 transition-all duration-500 why-reveal" style="background: var(--bg-card);">
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-gold/0 to-gold/0 group-hover:from-gold/5 group-hover:to-rosegold/5 transition-all duration-500"></div>
